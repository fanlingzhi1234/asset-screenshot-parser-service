# App
APP_NAME=asset-screenshot-parser-service
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8010
LOG_LEVEL=INFO
PYTHON_IMAGE=mirror.gcr.io/library/python:3.11-slim

# Storage
DATABASE_URL=sqlite:///./data/parser.db
UPLOAD_DIR=./data/uploads

# OCR
# Supported: umi_http, umi_cli, mock
OCR_PROVIDER=umi_http
OCR_TIMEOUT_SECONDS=30
UMI_OCR_BASE_URL=http://127.0.0.1:1224
UMI_OCR_CLI_PATH=umi-ocr

# Security
# Optional. If set, clients must send X-API-Key.
API_KEY=
